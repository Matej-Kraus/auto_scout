# Lokalne staci nechat SQLite. V produkci Neon Postgres.
DATABASE_URL=sqlite:///local.db

# Telegram (z @BotFather + getUpdates)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Prah pro alert: 0.10 = posli kdyz je inzerat >=10 % pod predikci
DEAL_THRESHOLD=0.10

# Posilat alerty na Telegram? false = jen loguj (dry run)
NOTIFY_ENABLED=false

# Lokalne za firemni TLS proxy, ktera lame SSL? Pak SSL_VERIFY=false.
# V produkci (Actions/Vercel) nech true.
SSL_VERIFY=true
